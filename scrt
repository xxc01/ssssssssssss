local function trim(value)
    if type(value) ~= "string" then
        return ""
    end

    return value:match("^%s*(.-)%s*$") or ""
end

local function normalize(value)
    return trim(value):lower()
end

local function parseUsers(text)
    local parsed = {}
    local seen = {}

    for raw in tostring(text or ""):gmatch("[^\r\n,; ]+") do
        local user = trim(raw)
        local key = user:lower()

        if user ~= "" and not seen[key] then
            seen[key] = true
            table.insert(parsed, user)
        end
    end

    return parsed
end

local function usersToText(list)
    return table.concat(list or {}, "\n")
end

local function getFullPetName(petData)
    local variants = {}

    if petData.sh then
        table.insert(variants, "Shiny")
    end

    if petData.pt == 2 then
        table.insert(variants, "Rainbow")
    elseif petData.pt == 1 then
        table.insert(variants, "Golden")
    end

    if #variants > 0 then
        return table.concat(variants, " ") .. " " .. petData.id
    end

    return petData.id
end

local function getVariant(petData)
    if petData.sh and petData.pt == 2 then
        return "Shiny Rainbow"
    end

    if petData.sh and petData.pt == 1 then
        return "Shiny Golden"
    end

    if petData.sh then
        return "Shiny"
    end

    if petData.pt == 2 then
        return "Rainbow"
    end

    if petData.pt == 1 then
        return "Golden"
    end

    return "Normal"
end

