    UI.SetStatus("Load failed")
    UI.SetCurrent("Library/Client did not load.")
    UI.Log("Library/Client did not load.")
    return
end

Network = require(Client:WaitForChild("Network"))
Save = require(Client:WaitForChild("Save"))

local function waitForSave(timeout)
    local start = tick()

    while tick() - start < timeout do
        local ok, data = pcall(function()
            return Save.Get()
        end)

        if ok and data and data.Inventory and data.Inventory.Pet then
            return data
        end

        task.wait(0.25)
    end

    return nil
end

local function getPet(uid)
    local saveData = Save.Get()
    local pets = saveData and saveData.Inventory and saveData.Inventory.Pet
    return pets and pets[uid] or nil
end

local function getPetAmount(uid)
    local pet = getPet(uid)
    if not pet then
        return 0
    end

    return math.max(1, math.floor(tonumber(pet._am) or 1))
end

local function unlockPet(uid)
    local pet = getPet(uid)

    if not pet or not pet._lk then
        return true
    end

    for _ = 1, 5 do
        pcall(function()
            Network.Invoke("LockingSetLocked", uid, false)
        end)

        task.wait(0.4)

        pet = getPet(uid)
        if pet and not pet._lk then
            return true
        end
    end

    return false
end

local function petMatches(petData)
    local targetName = normalize(getTargetName())
    local targetVariant = normalize(getTargetVariant())

    if targetName == "" or not petData or not petData.id then
        return false
    end

    local petBase = normalize(petData.id)
    local petFull = normalize(getFullPetName(petData))
    local petVariant = normalize(getVariant(petData))
    local nameMatches = targetName == petBase or targetName == petFull
    local variantMatches = targetVariant == "" or targetVariant == "any" or targetVariant == petVariant

    return nameMatches and variantMatches
end

local function findStack()
    if normalize(getTargetClass()) ~= "pet" then
        return nil, "Only Pet class is supported right now."
    end

    local saveData = Save.Get()
    local pets = saveData and saveData.Inventory and saveData.Inventory.Pet
    local amountNeeded = getTargetAmount()

    if not pets then
        return nil, "Pet inventory is not loaded."
    end

    for uid, petData in pairs(pets) do
        if petMatches(petData) then
            local amount = math.max(1, math.floor(tonumber(petData._am) or 1))

            if amount >= amountNeeded then
                if unlockPet(uid) then
                    local currentPet = getPet(uid)

                    if currentPet and not currentPet._lk then
                        return {
                            UID = uid,
                            Name = getFullPetName(currentPet),
                            Amount = amountNeeded,
                            BeforeAmount = getPetAmount(uid),
                        }
                    end
                end
            else
                return nil, "Found matching stack, but only " .. amount .. "/" .. amountNeeded .. " available."
            end
        end
    end

    return nil, "No matching pet stack found."
end

local function normalizeMailboxResult(result, ...)
    local extras = {...}

    if result == true then
        return true
    end

    if type(result) == "table" then
        if result.success == true or result.Success == true or result[1] == true then
            return true
        end

        local message = result.message or result.Message or result.error or result.Error
        if type(message) == "string" and message ~= "" then
            return false, message
        end
    end

    for _, value in ipairs(extras) do
        if type(value) == "string" and value ~= "" then
            return false, value
        end
    end

    if type(result) == "string" and result ~= "" then
        return false, result
    end

    return false, "Mailbox rejected request"
end

local function sendPet(recipient, message, petInfo)
    local lastError = "Unknown error"

    for attempt = 1, MaxRetries do
        if shouldStop then
            return false, "Stopped"
        end

        local beforeAmount = getPetAmount(petInfo.UID)
        local ok, result, result2, result3 = pcall(function()
            return Network.Invoke("Mailbox: Send", recipient, message, "Pet", petInfo.UID, petInfo.Amount)
        end)

        if ok then
            local success, reason = normalizeMailboxResult(result, result2, result3)
            if success then
                return true
            end

            task.wait(0.6)

            local afterAmount = getPetAmount(petInfo.UID)
            if afterAmount <= math.max(0, beforeAmount - petInfo.Amount) then
                return true
            end

            lastError = reason or lastError
        else
            lastError = tostring(result)
        end

        UI.Log("Retry " .. attempt .. ": " .. tostring(lastError))
        task.wait(0.75 + attempt * 0.25)
    end

    return false, lastError
end

local function sleepWithStop(duration)
    local elapsed = 0

    while elapsed < duration do
        if shouldStop then
            return false
        end

        local step = math.min(0.1, duration - elapsed)
        task.wait(step)
        elapsed = elapsed + step
    end

    return true
end

local function runMailer()
    if isRunning then
        UI.Log("Already running.")
        return
    end

    if #Users == 0 then
        UI.SetStatus("Setup needed")
        UI.SetCurrent("Paste users in setup and click Apply setup.")
        UI.Log("No users loaded.")
        return
    end

    if getTargetName() == "" then
        UI.SetStatus("Setup needed")
        UI.SetCurrent("Enter an item name in setup and click Apply setup.")
        UI.Log("No item name set.")
        return
    end

    if nextUserIndex > #Users then
        UI.SetStatus("Finished")
        UI.SetCurrent("Already finished. Press Reset to run again.")
        UI.SetProgress(#Users, #Users)
        UI.SetStats("Sent: " .. completedUsers .. " | Failed: " .. failedUsers)
        UI.Log("Already finished. Reset to start over.")
        return
    end

    isRunning = true
    shouldStop = false
    UI.SetRunning(true)
    UI.SetStatus("Loading")
    UI.SetCurrent("Loading save data...")
    UI.SetProgress(completedUsers + failedUsers, #Users)
    UI.SetStats("Sent: " .. completedUsers .. " | Failed: " .. failedUsers)
    UI.Log("Starting at user " .. nextUserIndex .. "/" .. #Users)

    if not waitForSave(30) then
        UI.SetStatus("Load failed")
        UI.SetCurrent("Save data did not load.")
        UI.Log("Save data did not load.")
        UI.SetRunning(false)
        isRunning = false
        return
    end

    UI.SetStatus("Running")

    for index = nextUserIndex, #Users do
        local recipient = Users[index]

        if shouldStop then
            UI.SetStatus("Paused")
            UI.SetCurrent("Paused at user " .. nextUserIndex .. "/" .. #Users .. ". Click Start to resume.")
            UI.Log("Paused. Next user: " .. tostring(Users[nextUserIndex] or "done"))
            UI.SetRunning(false)
            isRunning = false
            return
        end

        local message = Messages[1] or "anthony mailer on top"
        UI.SetStatus("Mailing")
        UI.SetCurrent("User " .. index .. "/" .. #Users .. ": " .. recipient)
        UI.Log("Preparing " .. recipient)

        local petInfo, findError = findStack()
        if not petInfo then
            UI.SetStatus("Stopped")
            UI.SetCurrent(findError or "No matching stack found.")
            UI.Log("Stopped: " .. tostring(findError))
            UI.SetRunning(false)
            isRunning = false
            return
        end

        UI.SetCurrent("Sending " .. petInfo.Amount .. " " .. petInfo.Name .. " to " .. recipient)
        local success, err = sendPet(recipient, message, petInfo)

        if success then
            completedUsers = completedUsers + 1
            nextUserIndex = index + 1
            UI.SetProgress(completedUsers + failedUsers, #Users)
            UI.SetStats("Sent: " .. completedUsers .. " | Failed: " .. failedUsers)
            UI.Log("Sent " .. petInfo.Amount .. " to " .. recipient)
        elseif err == "Stopped" then
            UI.SetStatus("Paused")
            UI.SetCurrent("Paused at user " .. nextUserIndex .. "/" .. #Users .. ". Click Start to resume.")
            UI.Log("Paused. Next user: " .. tostring(Users[nextUserIndex] or "done"))
            UI.SetRunning(false)
            isRunning = false
            return
        else
            failedUsers = failedUsers + 1
            nextUserIndex = index + 1
            UI.SetProgress(completedUsers + failedUsers, #Users)
            UI.SetStats("Sent: " .. completedUsers .. " | Failed: " .. failedUsers)
            UI.Log("Failed " .. recipient .. ": " .. tostring(err))
        end

        if SendDelay > 0 and not sleepWithStop(SendDelay) then
            UI.SetStatus("Paused")
            UI.SetCurrent("Paused at user " .. nextUserIndex .. "/" .. #Users .. ". Click Start to resume.")
            UI.Log("Paused. Next user: " .. tostring(Users[nextUserIndex] or "done"))
            UI.SetRunning(false)
            isRunning = false
            return
        end
    end

    UI.SetStatus("Finished")
    UI.SetCurrent("Done. Sent: " .. completedUsers .. " | Failed: " .. failedUsers)
    UI.SetProgress(#Users, #Users)
    UI.SetStats("Sent: " .. completedUsers .. " | Failed: " .. failedUsers)
    UI.Log("Finished one-time pass.")
    nextUserIndex = #Users + 1
    UI.SetRunning(false)
    isRunning = false
end

