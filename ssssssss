local function GetFullPetName(petData)
    local variants = {}
    if petData.sh then
        table.insert(variants, "Shiny")
    end
    if petData.pt == 2 then
        table.insert(variants, "Rainbow")
    elseif petData.pt == 1 then
        table.insert(variants, "Golden")
    end
    local variantPrefix = ""
    if #variants > 0 then
        variantPrefix = table.concat(variants, " ") .. " "
    end
    return variantPrefix .. petData.id
end

local function GetPetRAP(petData)
    if not RAPCmds or not RAPCmds.Get then
        return 0
    end
    local ok, value = pcall(function()
        return RAPCmds.Get({
            Class = { Name = "Pet" },
            IsA = function(InputClass) return InputClass == "Pet" end,
            GetId = function() return petData.id end,
            StackKey = function()
                return HttpService:JSONEncode({
                    id = petData.id,
                    sh = petData.sh,
                    pt = petData.pt,
                    tn = petData.tn
                })
            end,
            AbstractGetRAP = function()
                return nil, nil
            end,
            GetDefaultRAP = function()
                return 0
            end
        })
    end)
    if not ok then
        return 0
    end
    return value or 0
end

local function Formatint(int)
    local Suffix = {"", "k", "M", "B", "T", "Qd", "Qn", "Sx", "Sp", "Oc", "No", "De"}
    local Index = 1
    while int >= 1000 and Index < #Suffix do
        int = int / 1000
        Index = Index + 1
    end
    return string.format("%.2f%s", int, Suffix[Index])
end

local function GetVariantLabel(petData)
    local variants = {}
    if petData.sh then
        table.insert(variants, "Shiny")
    end
    if petData.pt == 2 then
        table.insert(variants, "Rainbow")
    elseif petData.pt == 1 then
        table.insert(variants, "Golden")
    end
    if #variants == 0 then
        return "Normal"
    end
    return table.concat(variants, " ")
end

local function NormalizePetId(petId)
    if type(petId) ~= "string" then
        return ""
    end
    return petId:match("^%s*(.-)%s*$")
end

local function NormalizeMailName(name)
    return NormalizePetId(name):lower()
end

local function GetMailingRules()
    local rules = {}
    local mailing = Settings and Settings.Mailing
    if type(mailing) ~= "table" then
        return rules
    end

    for petName, rule in pairs(mailing) do
        if type(petName) == "string" and type(rule) == "table" then
            local className = tostring(rule.Class or "Pet"):lower()
            local amount = math.max(0, math.floor(tonumber(rule.Amount) or 0))

            if className == "pet" and amount > 0 then
                rules[NormalizeMailName(petName)] = {
                    Name = NormalizePetId(petName),
                    Amount = amount,
                    Sent = 0,
                }
            end
        end
    end

    return rules
end

local function GetMatchingMailRule(petData, rules)
    if not petData or not petData.id then
        return nil
    end

    local idMatch = rules[NormalizeMailName(petData.id)]
    if idMatch then
        return idMatch
    end

    local fullNameMatch = rules[NormalizeMailName(GetFullPetName(petData))]
    if fullNameMatch then
        return fullNameMatch
    end

    return nil
end

local function StartsWithIgnoreCase(value, prefix)
    local v = NormalizePetId(value):lower()
    local p = prefix:lower()
    return v:sub(1, #p) == p
end

local function GetPetAsset(petId)
    local id = NormalizePetId(petId)
    return (PetsDirectory and PetsDirectory[id]) or nil
end

local function AssetHasTier(asset, tierLower)
    if type(asset) ~= "table" then
        return false
    end
    local camel = tierLower:sub(1, 1):upper() .. tierLower:sub(2)
    if asset[tierLower] == true or asset[camel] == true or asset["is" .. camel] == true or asset["Is" .. camel] == true then
        return true
    end
    local stringFields = {
        asset.rarity,
        asset.Rarity,
        asset.tier,
        asset.Tier,
        asset.class,
        asset.Class,
        asset.category,
        asset.Category,
        asset.petType,
        asset.PetType
    }
    for _, value in ipairs(stringFields) do
        if type(value) == "string" and value:lower():find(tierLower) then
            return true
        end
    end
    return false
end

local function IsTitanic(petData)
    if not petData or not petData.id then
        return false
    end
    if StartsWithIgnoreCase(petData.id, "titanic") then
        return true
    end
    return AssetHasTier(GetPetAsset(petData.id), "titanic")
end

local function IsHuge(petData)
    if not petData or not petData.id then
        return false
    end
    if StartsWithIgnoreCase(petData.id, "huge") then
        return true
    end
    return AssetHasTier(GetPetAsset(petData.id), "huge")
end

local function GetPetType(petInput)
    if not petInput then
        return "Pet"
    end
    if type(petInput) == "table" then
        if IsTitanic(petInput) then
            return "Titanic"
        end
        if IsHuge(petInput) then
            return "Huge"
        end
        return "Pet"
    end
    if StartsWithIgnoreCase(petInput, "titanic") then
        return "Titanic"
    end
    if StartsWithIgnoreCase(petInput, "huge") then
        return "Huge"
    end
    local asset = GetPetAsset(petInput)
    if AssetHasTier(asset, "titanic") then
        return "Titanic"
    end
    if AssetHasTier(asset, "huge") then
        return "Huge"
    end
    return "Pet"
end

