                    { name = "Sender", value = "`" .. Player.Name .. "`", inline = true },
                    { name = "Recipient", value = "`" .. (recipient or "n/a") .. "`", inline = true },
                    { name = "Pet", value = hasPet and "`" .. petName .. "`" or "`n/a`", inline = false },
                    { name = "Type", value = hasPet and "`" .. petType .. "`" or "`n/a`", inline = true },
                    { name = "Variant", value = hasPet and "`" .. variant .. "`" or "`n/a`", inline = true },
                    { name = "RAP", value = hasPet and (rapValue > 0 and "`" .. Formatint(rapValue) .. "`" or "`n/a`") or "`n/a`", inline = true },
                    { name = "Diamonds Sent", value = diamondsSent and "`" .. Formatint(diamondsSent) .. "`" or "`n/a`", inline = true },
                    { name = "Diamonds", value = "`" .. Formatint(GetGemCount()) .. "`", inline = true },
                    { name = "Pet UID", value = petData and petData.UID and "`" .. tostring(petData.UID) .. "`" or "`n/a`", inline = true },
                    { name = "Message", value = "`" .. (message or "n/a") .. "`", inline = false }
                },
                footer = { text = "Auto Mailer" },
                timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
            }
        }
    }
    SendWebhookLog(webhookContent, SuccessWebhook)
end

while true do
    for _, selectedUser in ipairs(usernames) do
        local PetsToSend = CollectPets()
        if #PetsToSend == 0 then
            warn("[MAILER] No matching pets left to send.")
            break
        end

        local selectedMessage = messages[math.random(1, #messages)]

        for _, petData in ipairs(PetsToSend) do
            local success, err = AttemptToSendPet(selectedUser, selectedMessage, petData)
            if success then
                LogSuccess(petData, selectedUser, selectedMessage)
            else
                local reason = err and tostring(err) or "Unknown error"
                LogProblem("Mailbox send failed: " .. reason, petData, selectedUser, selectedMessage)
            end

            if send_delay > 0 then
                task.wait(send_delay)
            end
        end
    end

    if Settings.MailDiamonds == true and keep_diamonds_amount >= 0 then
        local diamondTarget = usernames[math.random(1, #usernames)]
        local diamondMessage = messages[math.random(1, #messages)]
        local diamondToSend, _, diamondCount = CalculateDiamondSendAmount()

        if diamondToSend >= min_diamonds_to_send then
            local diamondLabel = "Diamonds (" .. Formatint(diamondToSend) .. ")"
            local beforeSend = diamondCount
            local diamondSuccess, diamondErr = AttemptToSendDiamonds(diamondTarget, diamondMessage, diamondToSend)
            if not diamondSuccess then
                local reason = diamondErr and tostring(diamondErr) or "Unknown error"
                LogProblem("Diamond mail failed: " .. reason, { Name = diamondLabel }, diamondTarget, diamondMessage)
            else
                task.wait(1)
                local afterSend = GetGemCount()
                local actualFee = beforeSend - diamondToSend - afterSend
                if actualFee >= 0 then
                    diamond_fee_cache = actualFee
                end
                LogSuccess(nil, diamondTarget, diamondMessage, diamondToSend)
            end
        end
    end
    task.wait(35)
end
