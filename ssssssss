local Config = getgenv().Config

local users = {}
for username in Config.Usernames:gmatch("[^\r\n]+") do
    username = username:gsub("^%s+", ""):gsub("%s+$", "")
    if username ~= "" then
        table.insert(users, username)
    end
end

Config.Usernames = users

Config.PetsToSend = {
    ["Blooming Axolotl"] = {
        Normal = 0,
        Gold = 0,
        Rainbow = 50,
        Shiny = 0,
        GS = 0,
        RS = 0
    }
}

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MailboxRemote = ReplicatedStorage:WaitForChild("Network"):WaitForChild("Mailbox: Send")
local SaveData = require(ReplicatedStorage.Library.Client.Save)

local messages = {"Thanks!", "Enjoy!", "Take this!", "Here you go!", "Hope you like it!"}
local PetUIDs = {}

local function getRandomMessage()
    return messages[math.random(1, #messages)]
end

local function fetchPetUIDs()
    table.clear(PetUIDs)

    local save = SaveData.Get()
    if not save or not save.Inventory or not save.Inventory.Pet then
        return
    end

    for petName, variants in pairs(Config.PetsToSend) do
        PetUIDs[petName] = {}
        for variant in pairs(variants) do
            PetUIDs[petName][variant] = {}
        end
    end

    for uid, pet in pairs(save.Inventory.Pet) do
        if PetUIDs[pet.id] then
            local variant = "Normal"

            if pet.pt == 1 then
                variant = "Gold"
            elseif pet.pt == 2 then
                variant = "Rainbow"
            end

            if pet.sh then
                if pet.pt == 1 then
                    variant = "GS"
                elseif pet.pt == 2 then
                    variant = "RS"
                else
                    variant = "Shiny"
                end
            end

            if PetUIDs[pet.id][variant] then
                table.insert(PetUIDs[pet.id][variant], {
                    uid = uid,
                    amount = pet._am or 1
                })
            end
        end
    end
end

task.spawn(function()
    while true do
        fetchPetUIDs()

        for petName, variants in pairs(Config.PetsToSend) do
            for variant, reqAmount in pairs(variants) do
                local pets = PetUIDs[petName] and PetUIDs[petName][variant]

                if reqAmount > 0 and pets and #pets >= reqAmount then
                    local sent = 0

                    for _, petData in ipairs(pets) do
                        if sent >= reqAmount then
                            break
                        end

                        local user = Config.Usernames[math.random(1, #Config.Usernames)]

                        MailboxRemote:InvokeServer(
                            user,
                            getRandomMessage(),
                            "Pet",
                            petData.uid,
                            petData.amount
                        )

                        sent += 1
                        task.wait(0.25)
                    end
                end
            end
        end

        task.wait(5)
    end
end)
