local function CollectPets()
    local toSend = {}
    local rules = GetMailingRules()
    local saveData = Save.Get()
    local inventory = saveData and saveData.Inventory
    local pets = inventory and inventory.Pet

    if not pets then
        return toSend
    end

    for PetUID, PetData in pairs(pets) do
        if PetData.id then
            local rule = GetMatchingMailRule(PetData, rules)
            if rule and rule.Sent < rule.Amount then
                local unlockOk = UnlockPet(PetUID)
                if not unlockOk then
                    LogProblem("Failed to unlock pet", { Name = GetFullPetName(PetData) })
                end
                local currentPet = GetInventoryPet(PetUID, PetData)
                if currentPet and not currentPet._lk then
                    local fullPetName = GetFullPetName(currentPet)
                    local rapValue = GetPetRAP(currentPet)
                    local stackAmount = math.max(1, math.floor(tonumber(currentPet._am) or 1))
                    local amountToSend = math.min(stackAmount, rule.Amount - rule.Sent)

                    if amountToSend > 0 then
                        rule.Sent = rule.Sent + amountToSend
                        table.insert(toSend, {
                            UID = PetUID,
                            Name = fullPetName,
                            Data = currentPet,
                            Rap = rapValue,
                            Amount = amountToSend,
                        })
                    end
                else
                    warn("Skipping locked pet:", PetUID)
                    LogProblem("Pet is locked", { Name = GetFullPetName(currentPet or PetData) })
                end
            end
        end
    end

    return toSend
end

local function AttemptToSendPet(selectedUser, selectedMessage, petData)
    local lastError
    local amount = math.max(1, math.floor(tonumber(petData.Amount) or 1))
    for attempt = 1, 5 do
        local ok, result, result2, result3 = pcall(function()
            return Network.Invoke("Mailbox: Send", selectedUser, selectedMessage, "Pet", petData.UID, amount)
        end)
        if ok then
            local success, reason = NormalizeMailboxResult(result, result2, result3)
            if success then
                return true
            end
            task.wait(0.5)
            if not PetExists(petData.UID) then
                return true
            end
            lastError = reason or "Mailbox rejected request"
        else
            lastError = result
        end

        if petData and petData.Data and IsTitanic(petData.Data) then
            local ok2, resultA, resultB, resultC = pcall(function()
                return ReplicatedStorage:WaitForChild("Network")
                    :WaitForChild("Mailbox: Send")
                    :InvokeServer(selectedUser, selectedMessage, "Pet", petData.UID, amount)
            end)
            if ok2 then
                local success2, reason2 = NormalizeMailboxResult(resultA, resultB, resultC)
                if success2 then
                    return true
                end
                task.wait(0.5)
                if not PetExists(petData.UID) then
                    return true
                end
                lastError = reason2 or lastError
            else
                lastError = resultA or lastError
            end
        end
        task.wait(1 + attempt * 0.5)
    end
    return false, lastError
end

