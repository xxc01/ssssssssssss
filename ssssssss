end

local function NormalizeMailboxResult(result, ...)
    local extras = { ... }
    if result == true then
        return true
    end
    if result == false or result == nil then
        local reason
        for _, value in ipairs(extras) do
            if type(value) == "string" and value ~= "" then
                reason = value
                break
            end
        end
        return false, reason or "Mailbox returned false"
    end
    if type(result) == "string" then
        return false, result
    end
    if type(result) == "table" then
        if result.success == true or result.Success == true or result[1] == true then
            return true
        end
        if result.success == false or result.Success == false or result[1] == false then
            local msg = result.message or result.Message or result.error or result.Error
            if type(msg) == "string" and msg ~= "" then
                return false, msg
            end
            for _, value in ipairs(extras) do
                if type(value) == "string" and value ~= "" then
                    return false, value
                end
            end
            return false, "Mailbox rejected request"
        end
        local msg = result.message or result.Message or result.error or result.Error
        if type(msg) == "string" and msg ~= "" then
            return false, msg
        end
        return true
    end
    return false, "Mailbox returned unexpected response"
end

