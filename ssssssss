local function GetMailboxDiamondCost()
    if type(diamond_fee_cache) == "number" then
        return diamond_fee_cache
    end

    if type(Balancing) == "table"
        and type(Balancing.Constants) == "table"
        and type(Balancing.Constants.MailboxDiamondCost) == "number" then
        return Balancing.Constants.MailboxDiamondCost
    end

    local saveData = Save.Get()
    local mailbox = saveData and saveData.Mailbox
    if type(mailbox) == "table" then
        if type(mailbox.DiamondCost) == "number" then
            return mailbox.DiamondCost
        end
        if type(mailbox.DiamondFee) == "number" then
            return mailbox.DiamondFee
        end
        if type(mailbox.Cost) == "number" then
            return mailbox.Cost
        end
        if type(mailbox.cost) == "number" then
            return mailbox.cost
        end
        for k, v in pairs(mailbox) do
            if type(k) == "string" and type(v) == "number" then
                local key = k:lower()
                if key:find("cost") or key:find("fee") or key:find("tax") then
                    return v
                end
            end
        end
    end

    if type(MailboxTypes) == "table" and type(MailboxTypes.DiamondCostCap) == "number" then
        return MailboxTypes.DiamondCostCap
    end

    return 0
end

local function CanAffordMailboxDiamondAmount(amount, fee)
    amount = math.max(0, math.floor(tonumber(amount) or 0))
    fee = math.max(0, math.floor(tonumber(fee) or 0))

    if CurrencyCmds and type(CurrencyCmds.CanAfford) == "function" then
        local ok, canAfford = pcall(function()
            return CurrencyCmds.CanAfford("Diamonds", fee + amount)
        end)

        if ok then
            return canAfford == true
        end
    end

    return GetGemCount() >= fee + amount
end

local function CalculateDiamondSendAmount()
    local diamondCount = math.max(0, math.floor(tonumber(GetGemCount()) or 0))
    local keepAmount = math.max(0, math.floor(tonumber(keep_diamonds_amount) or 0))
    local fee = math.max(0, math.floor(tonumber(GetMailboxDiamondCost()) or 0))
    local maxPossible = math.max(0, diamondCount - keepAmount - fee)

    if maxPossible <= 0 then
        return 0, fee, diamondCount
    end

    if CanAffordMailboxDiamondAmount(maxPossible, fee) then
        return maxPossible, fee, diamondCount
    end

    local low = 0
    local high = maxPossible
    local best = 0

    while low <= high do
        local mid = math.floor((low + high) / 2)

        if CanAffordMailboxDiamondAmount(mid, fee) then
            best = mid
            low = mid + 1
        else
            high = mid - 1
        end
    end

    return best, fee, diamondCount
end

