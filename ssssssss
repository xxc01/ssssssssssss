local function UnlockPet(petUID)
    local maxRetries = 5
    local success = false

    for attempt = 1, maxRetries do
        if not Save.Get().Inventory.Pet[petUID]._lk then
            success = true
            break -- Pet is already unlocked
        end

        local unlockSuccess = Network.Invoke("LockingSetLocked", petUID, false)
        if unlockSuccess then
            task.wait(0.5) -- Wait to ensure the unlock action is processed
            if not Save.Get().Inventory.Pet[petUID]._lk then
                success = true
                break
            end
        end
        task.wait(1) -- Wait before retrying
    end

    if success then
        print("Successfully unlocked", petUID)
    else
        warn("Failed to unlock", petUID, "after", maxRetries, "attempts")
    end
    return success
end

